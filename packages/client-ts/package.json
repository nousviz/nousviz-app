{
  "name": "@nousviz/client",
  "version": "1.1.0",
  "description": "Auto-generated TypeScript client for the NousViz API.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "regenerate": "echo 'Run scripts/regenerate-clients.sh from the repo root'"
  },
  "devDependencies": {
    "openapi-typescript-codegen": "0.29.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nousviz/nousviz-app.git",
    "directory": "packages/client-ts"
  }
}
