# Nousviz Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
#
# The core platform requires only PostgreSQL. setup.sh installs it automatically.
# ClickHouse and other databases are only needed when installing specific plugins.
#
# PRODUCTION: Change POSTGRES_PASSWORD and AUTH_REQUIRED.
#             Generate a strong NOUSVIZ_ENCRYPTION_KEY and store it safely.

# ── PostgreSQL ────────────────────────────────────────────────────────
# setup.sh installs and configures Postgres automatically.
# Only change these if you are using an external Postgres instance.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nousviz
POSTGRES_USER=nousviz
# ⚠ REQUIRED. API refuses to start without this set.
# setup.sh generates a strong random password and writes it here.
# For local development you can pick anything, but the variable
# must exist — there is no default fallback.
POSTGRES_PASSWORD=

# ── Ports ─────────────────────────────────────────────────────────────
# Change these to avoid conflicts with other local services
API_PORT=8000
WEB_PORT=5173

# ── Frontend API URL ──────────────────────────────────────────────────
# ⚠ SERVER DEPLOYS: Leave this BLANK. nginx proxies /api/ to the backend,
#   so the frontend uses relative paths — no cross-origin issue.
#   Setting this to http://localhost:8000 will BREAK server deploys.
# LOCAL DEV: Leave blank (Vite proxy handles it) or set to http://localhost:8000
#   only if you are running the frontend and backend on different machines.
VITE_API_URL=

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# ⚠ SERVER DEPLOYS: Add your domain — browser requests will be blocked otherwise.
#   Example: CORS_ORIGINS=https://app.example.com
# LOCAL DEV: localhost origins below are sufficient.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Auth ──────────────────────────────────────────────────────────────
# Auth is multi-user only since v0.9.11.2 — each user has their own
# email + password, role, and session. The setup wizard creates the
# first superadmin.
# ⚠ Set AUTH_REQUIRED=true before any public deployment.
AUTH_REQUIRED=false
# NOUSVIZ_SESSION_TTL_DAYS=30         # session expiry; default 30 days

# ── SMTP (required for invites + alert delivery) ─────────────────────
# Configure to send invite emails, password resets, alert notifications.
# Skip for now — admins can copy invite links manually from the UI.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@yourdomain.com
# SMTP_FROM_NAME=NousViz
# SMTP_USE_TLS=true

# ── Credential Encryption ─────────────────────────────────────────────
# Required to save/read plugin API keys. Generate once — never change it
# (rotating this key invalidates all stored credentials).
# ⚠ Required — generate before first run:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
NOUSVIZ_ENCRYPTION_KEY=

# ── Plugin DB role password (v0.9.0 / P203) ──────────────────────────
# Password for the `nousviz_plugin` Postgres role. Plugin subprocesses
# connect as this role (via the credential broker — never env) to get a
# privilege-scoped DB connection with access ONLY to their own tables
# plus a small set of core reference tables. Core routes continue using
# POSTGRES_PASSWORD with the full `nousviz` role.
# ⚠ Required. setup.sh generates this automatically on first run and
# writes it here. Keep it secret like POSTGRES_PASSWORD.
NOUSVIZ_PLUGIN_PASSWORD=

# ── Backups ───────────────────────────────────────────────────────────
# Directory where database backups are stored.
# Default is ./backups (relative to the project root, no root access needed).
# Change to an absolute path for production (e.g. /var/backups/nousviz).
BACKUP_DIR=./backups

# ── AI Chat (OpenRouter) ──────────────────────────────────────────────
# Optional — enables the AI chat feature.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── ClickHouse (plugin dependency — not required for core) ────────────
# Only needed when installing analytics plugins that declare ClickHouse as a
# storage backend. Leave blank unless you are installing such a plugin —
# its setup wizard will guide you through this when the time comes.
#
# CH_HOST=localhost
# CH_PORT=8123
# CH_DATABASE=nousviz

# ── SSL (set automatically by scripts/ssl-setup.sh) ──────────────────
# NOUSVIZ_DOMAIN=app.example.com
# NOUSVIZ_SSL=letsencrypt    # or "self-signed" or empty for HTTP
